rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tasks
    // Document ID: taskId
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - deadline: string (required, ISO 8601 format)
    //   - priority: string (required, High|Medium|Low)
    //   - subject: string (required, 1-50 chars)
    //   - completed: bool (required)
    //   - uid: string (required, matches owner)
    //   - createdAt: timestamp (required)
    //   - completedAt: timestamp (optional)
    //
    // Collection: sessions
    // Document ID: sessionId
    // Fields:
    //   - slot: string (required, Morning|Afternoon|Evening)
    //   - title: string (required, 1-100 chars)
    //   - uid: string (required, matches owner)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidDateString(dateStr) {
      return dateStr is string && dateStr.matches("^\\d{4}-\\d{2}-\\d{2}.*");
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidTask(data) {
      return hasRequiredFields(['name', 'deadline', 'priority', 'subject', 'completed', 'uid', 'createdAt']) &&
             hasOnlyAllowedFields(['name', 'deadline', 'priority', 'subject', 'completed', 'uid', 'createdAt', 'completedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             isValidDateString(data.deadline) &&
             data.priority in ['High', 'Medium', 'Low'] &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() <= 50 &&
             data.completed is bool &&
             data.uid == request.auth.uid &&
             data.createdAt is timestamp &&
             (!('completedAt' in data) || data.completedAt == null || data.completedAt is timestamp);
    }

    function isValidSession(data) {
      return hasRequiredFields(['slot', 'title', 'uid', 'createdAt']) &&
             hasOnlyAllowedFields(['slot', 'title', 'uid', 'createdAt']) &&
             data.slot in ['Morning', 'Afternoon', 'Evening'] &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.uid == request.auth.uid &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidTask(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidTask(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /sessions/{sessionId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSession(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidSession(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
